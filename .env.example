# WebCraft — environment variables
# Copy to .env and edit before starting

# ── WebSocket bridge ───────────────────────────────────────────────────────────
WS_PORT=8080
# CERT_PATH=/etc/letsencrypt/live/your-domain.com/fullchain.pem
# KEY_PATH=/etc/letsencrypt/live/your-domain.com/privkey.pem

# ── Minecraft server ───────────────────────────────────────────────────────────
MC_PORT=25565
MC_VERSION=1.20.4
ONLINE_MODE=true
MAX_PLAYERS=20
VIEW_DISTANCE=8
MOTD=§aWebCraft §7— hosted on the web ✨

# ── Security ───────────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=10

# ── Admin API ───────────────────────────────────────────────────────────────────
ADMIN_PORT=9090
# ADMIN_TOKEN=change-me-to-a-secure-token

# ── World persistence ─────────────────────────────────────────────────────────
WORLD_DIR=./world
AUTOSAVE_MIN=5

# ── Plugins ───────────────────────────────────────────────────────────────────
PLUGINS_DIR=./plugins

# ── Anti-spam ───────────────────────────────────────────────────────────────────
ANTISPAM_MSG_MAX=5
ANTISPAM_WINDOW_MS=3000
ANTISPAM_MUTE_SECONDS=30

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
