# WebCraft — environment variables
# Copy to .env and edit before starting

# ── WebSocket bridge ───────────────────────────────────────────────────────────
WS_PORT=8080

# Optional TLS (WSS) — provide paths to your cert and key files
# CERT_PATH=/etc/ssl/certs/webcraft.crt
# KEY_PATH=/etc/ssl/private/webcraft.key

# ── Minecraft server ───────────────────────────────────────────────────────────
MC_PORT=25565
MC_VERSION=1.20.4
ONLINE_MODE=true
MAX_PLAYERS=20
VIEW_DISTANCE=8
MOTD=§aWebCraft §7— hosted on the web ✨

# ── Security ───────────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=10

# ── Admin API (internal only, never expose publicly) ──────────────────────────
ADMIN_PORT=9090
# ADMIN_TOKEN=change-me-to-a-secure-token

# ── World persistence ─────────────────────────────────────────────────────────
WORLD_DIR=./world
AUTOSAVE_MIN=5

# ── Plugins ───────────────────────────────────────────────────────────────────
PLUGINS_DIR=./plugins

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO  (DEBUG | INFO | WARN | ERROR)
