{
  "name": "webcraft",
  "version": "0.1.0",
  "description": "A Minecraft server designed to run on standard web hosting via WebSocket transport",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit",
    "lint": "node --check src/*.js plugins/*.js tests/*.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": [
      "src/**/*.js",
      "plugins/**/*.js",
      "!plugins/core-api.js"
    ],
    "coverageDirectory": "coverage",
    "testTimeout": 10000
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Kofysh/webcraft.git"
  },
  "keywords": [
    "minecraft",
    "server",
    "websocket",
    "web-hosting",
    "nodejs",
    "prismarine",
    "flying-squid",
    "open-source"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.5",
    "flying-squid": "^1.7.0",
    "minecraft-data": "^3.63.0",
    "prismarine-world": "^2.1.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "jest": "^29.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
